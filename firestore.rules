rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Default-Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, Hardened Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email.lower() == "laieth772@gmail.com";
    }

    // 2. Settings: Publicly readable for active channel configurations, editable only by admin
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Coupons: Publicly readable to validate discounts during checkout, writable by admin
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Products: Publicly readable for storefront, editable strictly by admin
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Orders: Publicly writable (create) for customers, read/write protected for admin only
    match /orders/{orderId} {
      allow create: if request.resource.data.customerName is string &&
                    request.resource.data.customerPhone is string &&
                    request.resource.data.customerAddress is string &&
                    request.resource.data.totalAmount is number;
      allow read, update, delete: if isAdmin();
    }
  }
}
